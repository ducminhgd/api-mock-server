# Database
# Supported drivers: sqlite, postgres, mariadb
DB_DRIVER=sqlite

# SQLite: file path inside the container
DB_DSN=/data/app.db

# PostgreSQL / MariaDB (uncomment and fill when switching driver)
# DB_DSN=postgres://user:password@db:5432/api_mock?sslmode=disable
# DB_DSN=user:password@tcp(db:3306)/api_mock?charset=utf8mb4&parseTime=True&loc=UTC

# Backend
PORT=8080

# Frontend
VITE_API_BASE=/api
