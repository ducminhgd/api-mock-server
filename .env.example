# PostgreSQL connection string
# SQLite alternative: sqlite://data.db
DATABASE_URL=postgres://api_mock:secret@db/api_mock_server

# Database credentials (used by the db service in docker-compose)
DB_NAME=api_mock_server
DB_USER=api_mock
DB_PASSWORD=secret

# Application
PORT=3000
LEPTOS_SITE_ADDR=0.0.0.0:3000
LEPTOS_SITE_ROOT=site
